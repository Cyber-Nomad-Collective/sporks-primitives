// Testing primitives — test framework, assertion, and coverage type definitions.
//
// Describes test cases, suites, assertions, mocks, and coverage
// collection patterns across language ecosystems.

// ── Types ───────────────────────────────────────────────

type TestCase {
    name: #Symbol,
    suite: #Symbol,
    status: #Symbol,
    duration_ms: #Symbol,
}

type TestSuite {
    name: #Symbol,
    test_count: #Symbol,
    framework: #Symbol,
}

type Assertion {
    assert_type: #Symbol,
    expected: #Symbol,
    actual: #Symbol,
    passed: #Symbol,
}

type Mock {
    name: #Symbol,
    target: #Symbol,
    behavior: #Symbol,
}

type Fixture {
    name: #Symbol,
    scope: #Symbol,
    setup: #Symbol,
    teardown: #Symbol,
}

type CoverageReport {
    lines_pct: #Symbol,
    branches_pct: #Symbol,
    functions_pct: #Symbol,
    uncovered: #Symbol,
}

// ── Patterns ────────────────────────────────────────────

pattern failing_test {
    TestCase
    and (status == "failed")
}

pattern passing_test {
    TestCase
    and (status == "passed")
}

pattern skipped_test {
    TestCase
    and (status == "skipped")
}

pattern jest_suite {
    TestSuite
    and (framework == "jest")
}

pattern vitest_suite {
    TestSuite
    and (framework == "vitest")
}

pattern equal_assertion {
    Assertion
    and (assert_type == "equal")
}

pattern mocked_function {
    Mock
    containing $target: #Symbol
}

pattern low_coverage {
    CoverageReport
    and (lines_pct == "low")
}

// ── Transforms ──────────────────────────────────────────

transform rename_test(old: #Symbol, new: #Symbol) {
    for TestCase {
        match name == $old;
        rewrite {
            name: $new,
        }
    }
}

transform change_assertion_expected(assert_name: #Symbol, new_expected: #Symbol) {
    for Assertion {
        match assert_type == $assert_name;
        rewrite {
            expected: $new_expected,
        }
    }
}

transform update_mock_behavior(mock_name: #Symbol, new_behavior: #Symbol) {
    for Mock {
        match name == $mock_name;
        rewrite {
            behavior: $new_behavior,
        }
    }
}

transform change_fixture_scope(fixture_name: #Symbol, new_scope: #Symbol) {
    for Fixture {
        match name == $fixture_name;
        rewrite {
            scope: $new_scope,
        }
    }
}
